PORT=3003
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://192.168.1.9:3000
NODE_ENV=development

# Database
DATABASE_URL="mysql://user:password@localhost:3306/vibepass"

# Redis (for Session, BullMQ, Socket.io adapter)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="super_secret_override_in_prod"
JWT_EXPIRATION="7d"

# External Services (Email/Magic Links)
EMAIL_MODE="smtp"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="your-gmail@gmail.com"
SMTP_FROM_NAME="VibePass Safety"
SMTP_SERVICE=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"

# WebRTC ICE Servers (Twilio TURN etc)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
