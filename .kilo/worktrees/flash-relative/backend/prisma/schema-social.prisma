// Complete Prisma Schema for Facebook-style Social Network
// Run: npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id                  String    @id @default(cuid()) @db.Char(36)
  username            String    @unique(map: "users_username_key") @db.VarChar(50)
  email               String    @unique(map: "users_email_key") @db.VarChar(255)
  passwordHash        String    @db.VarChar(255)
  
  firstName           String?   @db.VarChar(100)
  lastName            String?   @db.VarChar(100)
  bio                 String?   @db.Text
  intro               String?   @db.Text
  profilePhotoUrl     String?   @db.VarChar(500)
  coverPhotoUrl       String?   @db.VarChar(500)
  
  gender              String?   @db.VarChar(20)
  dateOfBirth         DateTime? @db.Date
  relationshipStatus  String?   @db.VarChar(50)
  
  workTitle           String?   @db.VarChar(100)
  workPlace           String?   @db.VarChar(200)
  education           String?   @db.VarChar(200)
  currentCity         String?   @db.VarChar(100)
  hometown            String?   @db.VarChar(100)
  
  accountPrivacy      String    @default("public") @db.VarChar(20) // public, friends, private
  isActive            Boolean   @default(true)
  
  createdAt           DateTime  @default(now()) @db.DateTime(0)
  updatedAt           DateTime  @default(now()) @updatedAt @db.DateTime(0)

  // Relations
  profile             UserProfile?
  posts               Post[]
  comments            Comment[]
  reactions           Reaction[]
  media               Media[]
  sentFriendRequests  FriendRequest[]  @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestReceiver")
  friends             UserFriend[]     @relation("UserFriends")
  friends2            UserFriend[]     @relation("UserFriends2")
  shares              Share[]
  blockedUsers        Block[]          @relation("Blocker")
  blockedBy           Block[]          @relation("Blocked")
  notifications       Notification[]
  bookmarks           Bookmark[]

  @@map("users")
}

model UserProfile {
  id              String  @id @default(cuid()) @db.Char(36)
  userId          String  @unique(map: "user_profiles_userId_key") @db.Char(36)
  favoriteQuotes  String? @db.Text
  about           String? @db.Text
  website         String? @db.VarChar(255)
  socialLinks     String? @db.Text // JSON
  
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("user_profiles")
}

model Session {
  id           String   @id @default(cuid()) @db.Char(36)
  userId       String   @db.Char(36)
  token        String   @unique(map: "sessions_token_key") @db.VarChar(500)
  refreshToken String?  @db.VarChar(500)
  deviceInfo   String?  @db.VarChar(255)
  ipAddress    String?  @db.VarChar(50)
  expiresAt    DateTime @db.DateTime(0)
  createdAt    DateTime @default(now()) @db.DateTime(0)
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "sessions_userId_idx")
  @@index([expiresAt], map: "sessions_expiresAt_idx")
  @@map("sessions")
}

// ============================================
// FRIENDSHIP SYSTEM
// ============================================

model FriendRequest {
  id          String   @id @default(cuid()) @db.Char(36)
  senderId    String   @db.Char(36)
  receiverId  String   @db.Char(36)
  status      String   @default("pending") @db.VarChar(20) // pending, accepted, rejected, cancelled
  createdAt   DateTime @default(now()) @db.DateTime(0)
  updatedAt   DateTime @default(now()) @updatedAt @db.DateTime(0)
  
  sender      User     @relation("FriendRequestSender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  receiver    User     @relation("FriendRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([senderId, receiverId], map: "friend_requests_sender_receiver_key")
  @@index([senderId], map: "friend_requests_senderId_idx")
  @@index([receiverId], map: "friend_requests_receiverId_idx")
  @@map("friend_requests")
}

model UserFriend {
  id          String   @id @default(cuid()) @db.Char(36)
  userId      String   @db.Char(36)
  friendId    String   @db.Char(36)
  createdAt   DateTime @default(now()) @db.DateTime(0)
  
  user        User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  friend      User     @relation("UserFriends2", fields: [friendId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, friendId], map: "user_friends_user_friend_key")
  @@index([userId], map: "user_friends_userId_idx")
  @@index([friendId], map: "user_friends_friendId_idx")
  @@map("user_friends")
}

// ============================================
// POSTS SYSTEM
// ============================================

model Post {
  id              String    @id @default(cuid()) @db.Char(36)
  authorId        String    @db.Char(36)
  content         String?   @db.Text
  postType        String    @default("original") @db.VarChar(20) // original, share
  sharedPostId    String?   @db.Char(36) // If shared, reference to original post
  shareCaption    String?   @db.Text // User's caption when sharing
  
  // Privacy & Status
  visibility      String    @default("public") @db.VarChar(20) // public, friends, private
  status          String    @default("active") @db.VarChar(20) // active, deleted, hidden
  feeling         String?   @db.VarChar(50)
  backgroundColor String?   @db.VarChar(20)
  
  // Counts (maintained by triggers or application logic)
  reactionsCount  Int       @default(0)
  commentsCount  Int       @default(0)
  sharesCount    Int       @default(0)
  
  createdAt       DateTime  @default(now()) @db.DateTime(0)
  updatedAt       DateTime  @default(now()) @updatedAt @db.DateTime(0)
  deletedAt       DateTime? @db.DateTime(0)

  // Relations
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  media           PostMedia[]
  reactions       Reaction[]
  comments        Comment[]
  shares          Share[]
  bookmarks       Bookmark[]

  // Self-reference for shares
  originalPost    Post?     @relation("OriginalShare", fields: [sharedPostId], references: [id], onDelete: SetNull)
  sharedPosts     Post[]    @relation("OriginalShare")

  @@index([authorId], map: "posts_authorId_idx")
  @@index([postType], map: "posts_postType_idx")
  @@index([createdAt], map: "posts_createdAt_idx")
  @@index([visibility], map: "posts_visibility_idx")
  @@index([sharedPostId], map: "posts_sharedPostId_idx")
  @@map("posts")
}

model PostMedia {
  id        String   @id @default(cuid()) @db.Char(36)
  postId    String   @db.Char(36)
  url       String   @db.VarChar(500)
  type      String   @db.VarChar(20) // image, video
  orderIndex Int     @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now()) @db.DateTime(0)

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([postId], map: "post_media_postId_idx")
  @@map("post_media")
}

// ============================================
// REACTIONS SYSTEM (Generic)
// ============================================

model Reaction {
  id          String   @id @default(cuid()) @db.Char(36)
  userId      String   @db.Char(36)
  targetType  String   @db.VarChar(20) // post, comment, share
  targetId    String   @db.Char(36)
  reactionType String  @db.VarChar(20) // like, love, care, haha, wow, sad, angry
  createdAt   DateTime @default(now()) @db.DateTime(0)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, targetType, targetId], map: "reactions_user_target_key")
  @@index([targetType, targetId], map: "reactions_target_idx")
  @@index([userId], map: "reactions_userId_idx")
  @@map("reactions")
}

// Reaction counts for performance (can be maintained by triggers)
model ReactionCount {
  id           String   @id @default(cuid()) @db.Char(36)
  targetType   String   @db.VarChar(20)
  targetId     String   @db.Char(36)
  reactionType String   @db.VarChar(20)
  count        Int      @default(0)

  @@unique([targetType, targetId, reactionType], map: "reaction_counts_target_key")
  @@map("reaction_counts")
}

// ============================================
// COMMENTS SYSTEM (Nested)
// ============================================

model Comment {
  id               String   @id @default(cuid()) @db.Char(36)
  postId           String   @db.Char(36)
  authorId         String   @db.Char(36)
  parentCommentId  String?  @db.Char(36) // For replies
  content          String   @db.Text
  status           String   @default("active") @db.VarChar(20) // active, deleted
  
  reactionsCount   Int      @default(0)
  repliesCount     Int      @default(0)
  
  createdAt        DateTime @default(now()) @db.DateTime(0)
  updatedAt        DateTime @default(now()) @updatedAt @db.DateTime(0)
  deletedAt        DateTime? @db.DateTime(0)

  post             Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  author           User     @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  parentComment    Comment? @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies          Comment[] @relation("CommentReplies")
  reactions        Reaction[]

  @@index([postId], map: "comments_postId_idx")
  @@index([authorId], map: "comments_authorId_idx")
  @@index([parentCommentId], map: "comments_parentCommentId_idx")
  @@map("comments")
}

// ============================================
// SHARES (Separate table for explicit shares with more metadata)
// ============================================

model Share {
  id              String   @id @default(cuid()) @db.Char(36)
  userId          String   @db.Char(36)
  originalPostId  String   @db.Char(36)
  caption         String?  @db.Text
  createdAt       DateTime @default(now()) @db.DateTime(0)

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  originalPost    Post     @relation(fields: [originalPostId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "shares_userId_idx")
  @@index([originalPostId], map: "shares_originalPostId_idx")
  @@map("shares")
}

// ============================================
// PRIVACY & SAFETY
// ============================================

model Block {
  id          String   @id @default(cuid()) @db.Char(36)
  blockerId   String   @db.Char(36)
  blockedId   String   @db.Char(36)
  createdAt   DateTime @default(now()) @db.DateTime(0)

  blocker     User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  blocked     User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([blockerId, blockedId], map: "blocks_blocker_blocked_key")
  @@map("blocks")
}

// ============================================
// NOTIFICATIONS (Optional but recommended)
// ============================================

model Notification {
  id          String   @id @default(cuid()) @db.Char(36)
  userId      String   @db.Char(36)
  type        String   @db.VarChar(50) // reaction, comment, share, friend_request, etc.
  targetType  String   @db.VarChar(20)
  targetId    String   @db.Char(36)
  actorId     String   @db.Char(36)
  message     String   @db.Text
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.DateTime(0)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId], map: "notifications_userId_idx")
  @@index([isRead], map: "notifications_isRead_idx")
  @@map("notifications")
}

// ============================================
// BOOKMARKS
// ============================================

model Bookmark {
  id        String   @id @default(cuid()) @db.Char(36)
  userId    String   @db.Char(36)
  postId    String   @db.Char(36)
  createdAt DateTime @default(now()) @db.DateTime(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, postId], map: "bookmarks_user_post_key")
  @@map("bookmarks")
}