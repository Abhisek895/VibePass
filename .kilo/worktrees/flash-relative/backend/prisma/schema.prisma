generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  passwordHash      String?
  username          String?
  age               Int?
  pronouns          String?
  genderPreference  String?
  interests         String?
  conversationIntent String?
  language          String            @default("en")
  timezone          String            @default("UTC")
  voiceComfort      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
  trustScore        Int               @default(100)
  isSuspended       Boolean           @default(false)
  isBanned          Boolean           @default(false)
  bio               String?
  readReceipts      Boolean           @default(true)
  lastUsernameChangeAt DateTime?
  profile           Profile?
  promptAnswers     PromptAnswer[]
  chats             Chat[]            @relation("ChatUser1")
  chats2            Chat[]            @relation("ChatUser2")
  messages          Message[]
  voiceSessions     VoiceSession[]    @relation("VoiceUser1")
  voiceSessions2    VoiceSession[]    @relation("VoiceUser2")
  reports           Report[]          @relation("Reporter")
  reports2          Report[]          @relation("Reported")
  blocks            Block[]           @relation("Blocker")
  blocks2           Block[]           @relation("Blocked")
  badges            Badge[]
  savedConnections  SavedConnection[] @relation("SavedUser1")
  savedConnections2 SavedConnection[] @relation("SavedUser2")
  userFeedback      UserFeedback[]    @relation("FeedbackFrom")
  userFeedback2     UserFeedback[]    @relation("FeedbackTo")
  rooms             RoomUser[]
  posts             Post[]
  postLikes         PostLike[]
  postComments      PostComment[]
  postShares        PostShare[]       @relation("UserSharedPosts")
  notifications     Notification[] @relation("NotificationUser")
  notificationsActor Notification[] @relation("NotificationActor")
  matchLikesSent    MatchLike[] @relation("LikeSender")
  matchLikesReceived MatchLike[] @relation("LikeTarget")
  matchPassesSent   MatchPass[] @relation("PassSender")

  @@map("users")
}


model Mood {
  id          String @id @default(uuid())
  name        String @unique
  emoji       String
  description String
  color       String
  category    String

  @@map("moods")
}

model ConversationIntent {
  id          String @id @default(uuid())
  name        String @unique
  description String
  icon        String
  isCasual    Boolean @default(false)

  @@map("conversation_intents")
}

model Prompt {
  id          String         @id @default(uuid())
  text        String
  type        String
  category    String
  difficulty  String
  isActive    Boolean        @default(true)
  isDaily     Boolean        @default(false)
  dailyTheme  String?
  expiresAt   DateTime?
  answers     PromptAnswer[]
  rooms       Room[]

  @@map("prompts")
}

model Room {
  id          String     @id @default(uuid())
  name        String
  description String
  promptId    String?
  theme       String
  isVoice     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  prompt      Prompt?    @relation(fields: [promptId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  chats       Chat[]
  users       RoomUser[]

  @@index([promptId])
  @@map("rooms")
}

model Profile {
  id               String   @id @default(uuid())
  userId           String   @unique
  intro            String?
  profilePhotoUrl  String?  @map("profile_photo_url")
  coverPhotoUrl    String?  @map("cover_photo_url")
  pronouns         String?
  interests        String?
  voiceOpen        Boolean  @default(false)
  gender           String?
  dateOfBirth      DateTime? @map("date_of_birth")
  relationshipStatus String? @map("relationship_status")
  workTitle        String?  @map("work_title")
  workPlace        String?  @map("work_place")
  education        String?
  currentCity      String?  @map("current_city")
  hometown         String?
  updatedAt        DateTime @default(now()) @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("profiles")
}

model PromptAnswer {
  id        String   @id @default(uuid())
  userId    String
  promptId  String
  answer    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, promptId])
  @@index([promptId])
  @@map("prompt_answers")
}

model Chat {
  id               String            @id @default(uuid())
  user1Id          String
  user2Id          String
  roomId           String?
  status           String            @default("active")
  startedAt        DateTime          @default(now())
  endedAt          DateTime?
  archivedAt       DateTime?
  user1            User              @relation("ChatUser1", fields: [user1Id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user2            User              @relation("ChatUser2", fields: [user2Id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  room             Room?             @relation(fields: [roomId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  messages         Message[]
  voiceSessions    VoiceSession[]
  reports          Report[]
  savedConnections SavedConnection[]
  userFeedback     UserFeedback[]

  @@index([user1Id])
  @@index([user2Id])
  @@index([roomId])
  @@map("chats")
}

model Message {
  id               String   @id @default(uuid())
  chatId           String
  senderId         String
  clientId         String?
  content          String   @db.Text
  moderationStatus String   @default("approved")
  deliveredAt      DateTime?
  readAt           DateTime?
  createdAt        DateTime @default(now())
  isDeletedForEveryone Boolean  @default(false)
  deletedBySender      Boolean  @default(false)
  deletedByRecipient   Boolean  @default(false)
  chat             Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sender           User     @relation(fields: [senderId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@index([clientId])
  @@map("messages")
}

model VoiceSession {
  id              String    @id @default(uuid())
  user1Id         String
  user2Id         String
  chatId          String
  status          String    @default("requested")
  durationSeconds Int?
  startedAt       DateTime?
  endedAt         DateTime?
  user1           User      @relation("VoiceUser1", fields: [user1Id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user2           User      @relation("VoiceUser2", fields: [user2Id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  chat            Chat      @relation(fields: [chatId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([user1Id])
  @@index([user2Id])
  @@index([chatId])
  @@map("voice_sessions")
}

model Report {
  id          String    @id @default(uuid())
  reporterId  String
  reportedId  String
  chatId      String?
  reason      String
  description String?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  reporter    User      @relation("Reporter", fields: [reporterId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reported    User      @relation("Reported", fields: [reportedId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  chat        Chat?     @relation(fields: [chatId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([reporterId])
  @@index([reportedId])
  @@index([chatId])
  @@map("reports")
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model Badge {
  id        String   @id @default(uuid())
  userId    String
  badgeType String
  count     Int      @default(1)
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("badges")
}

model SavedConnection {
  id      String    @id @default(uuid())
  user1Id String
  user2Id String
  chatId  String?
  label   String?
  savedAt DateTime  @default(now())
  user1   User      @relation("SavedUser1", fields: [user1Id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user2   User      @relation("SavedUser2", fields: [user2Id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  chat    Chat?     @relation(fields: [chatId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([user1Id, user2Id])
  @@index([user2Id])
  @@index([chatId])
  @@map("saved_connections")
}

model UserFeedback {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  chatId     String
  attributes String?
  createdAt  DateTime @default(now())
  fromUser   User     @relation("FeedbackFrom", fields: [fromUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  toUser     User     @relation("FeedbackTo", fields: [toUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([fromUserId])
  @@index([toUserId])
  @@index([chatId])
  @@map("user_feedback")
}

model RoomUser {
  id       String    @id @default(uuid())
  roomId   String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  room     Room      @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
  @@map("room_users")
}

model Post {
  id          String    @id @default(cuid())
  userId      String
  content     String
  imageUrl    String?
  isDarkMeme  Boolean   @default(false)
  likesCount  Int       @default(0)
  commentsCount Int     @default(0)
  sharesCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  likes       PostLike[]
  comments    PostComment[]
  shares      PostShare[] @relation("SharedOriginalPost")

  @@index([userId])
  @@index([createdAt])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@map("post_comments")
}

model PostShare {
  id                String   @id @default(cuid())
  originalPostId    String
  sharedByUserId    String
  createdAt         DateTime @default(now())
  originalPost      Post     @relation("SharedOriginalPost", fields: [originalPostId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sharedByUser      User     @relation("UserSharedPosts", fields: [sharedByUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([originalPostId])
  @@index([sharedByUserId])
  @@map("post_shares")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  type       String
  actorId    String
  targetId   String?
  targetType String?
  read       Boolean  @default(false)
  data       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotificationActor", fields: [actorId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

model MatchLike {
  id        String   @id @default(uuid())
  senderId  String
  targetId  String
  createdAt DateTime @default(now())

  sender    User     @relation("LikeSender", fields: [senderId], references: [id], onDelete: Cascade)
  target    User     @relation("LikeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([senderId, targetId])
  @@index([targetId])
  @@map("match_likes")
}

model MatchPass {
  id        String   @id @default(uuid())
  senderId  String
  targetId  String
  createdAt DateTime @default(now())

  sender    User     @relation("PassSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, targetId])
  @@index([targetId])
  @@map("match_passes")
}
